FLASK_SECRET_KEY=
APP_USERNAME=admin
APP_PASSWORD=
# Optional, preferred over APP_PASSWORD:
# APP_PASSWORD_HASH=
# Optional persistent runtime directory for Docker/Raspberry Pi deployments:
# DATA_DIR=/data
# Use true when users access the app through HTTPS, for example Cloudflare Tunnel:
# SESSION_COOKIE_SECURE=true
# Optional upload limit for PDFs and financial Excel files, in MiB:
# MAX_UPLOAD_MB=50

FUSIONSOLAR_USERNAME=
FUSIONSOLAR_PASSWORD=
FUSIONSOLAR_BASE_URL=
FUSIONSOLAR_LOGIN_ENDPOINT=/thirdData/login
FUSIONSOLAR_STATIONS_ENDPOINT=/thirdData/stations
FUSIONSOLAR_REALTIME_ENDPOINT=/thirdData/getStationRealKpi
FUSIONSOLAR_DEVICES_ENDPOINT=/thirdData/getDevList
FUSIONSOLAR_DEVICE_REALTIME_ENDPOINT=/thirdData/getDevRealKpi
FUSIONSOLAR_ALARMS_ENDPOINT=/thirdData/getAlarmList
FUSIONSOLAR_SYNC_HOURS=08:00,14:00
FUSIONSOLAR_PRODUCTION_SYNC_ENABLED=true
FUSIONSOLAR_PRODUCTION_SYNC_TIME=00:10
FUSIONSOLAR_DIAGNOSTICS_SYNC_ENABLED=true
FUSIONSOLAR_DIAGNOSTICS_SYNC_TIME=00:30
FUSIONSOLAR_RATE_LIMIT_MINUTES=60
FUSIONSOLAR_SESSION_CACHE_MINUTES=55
FUSIONSOLAR_PRODUCTION_KPI_MIN_INTERVAL_SECONDS=65
FUSIONSOLAR_PRODUCTION_KPI_DAILY_BUDGET=20
FUSIONSOLAR_PRODUCTION_KPI_DAILY_RESERVED_CALLS=2
FUSIONSOLAR_PRODUCTION_KPI_MONTH_CLOSE_RESERVED_CALLS=2
# Deixar vazios ate os limites oficiais Sigenergy serem validados.
SIGENERGY_PRODUCTION_MIN_INTERVAL_SECONDS=
SIGENERGY_PRODUCTION_DAILY_BUDGET=

SIGENERGY_ENABLED=false
SIGENERGY_APP_KEY=
SIGENERGY_APP_SECRET=
SIGENERGY_BASE_URL=https://api-eu.sigencloud.com
SIGENERGY_AUTH_ENDPOINT=/openapi/auth/login/key
SIGENERGY_SYSTEMS_ENDPOINT=/openapi/system
SIGENERGY_ENERGY_FLOW_ENDPOINT=/openapi/systems/{system_id}/energyFlow
SIGENERGY_ONBOARD_ENDPOINT=/openapi/board/onboard
SIGENERGY_REGION=eu
# Optional fallback when the account does not expose a systems list:
SIGENERGY_SYSTEM_IDS=
# Singular alias also supported:
# SIGENERGY_SYSTEM_ID=
SIGENERGY_SYNC_HOURS=08:00,14:00
SIGENERGY_SNAPSHOT_RETENTION_DAYS=90

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_DAILY_SUMMARY_ENABLED=false

# Optional: route distances by road for "Mapa e rotas".
OPENROUTESERVICE_API_KEY=
DEFAULT_DEPOT_NAME=Solcor Portugal
DEFAULT_DEPOT_ADDRESS=Av. Alm. Reis 54 3º, 1150-019 Lisboa
DEFAULT_DEPOT_LAT=
DEFAULT_DEPOT_LNG=
